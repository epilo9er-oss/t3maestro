# Fork Branding Configuration
# Copy this file to .env.fork and customize for your fork.
# The .env.fork file is gitignored and will not be committed.

# Display name for your fork (e.g., "T3 Maestro", "My Custom IDE")
T3_FORK_APP_NAME=T3 Maestro

# Organization domain for bundle IDs (e.g., "com.t3tools", "com.mycompany")
T3_FORK_DOMAIN=com.t3tools

# URL/file safe identifier (e.g., "t3maestro", "myide")
# Used for: userData directories, config file paths, Linux WM class
T3_FORK_SLUG=t3maestro

# GitHub repository for updates (e.g., "pingdotgg/t3maestro")
# Format: owner/repo
T3_FORK_REPO=pingdotgg/t3maestro
